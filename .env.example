### Docker Compose
PORT=3000
ADMINER_PORT=8080
POSTGRES_PORT=5432
BACKEND_PORT=8081

### PostgreSQL
POSTGRES_DB=phone_ai_caller
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgres

### Prisma / DB Connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

### Admin protection
ADMIN_SECRET_KEY=

### App URL (used for absolute links if needed)
NEXT_PUBLIC_APP_URL=http://0.0.0.0:${PORT}

### Internal backend url used by Next.js server-side proxies
BACKEND_INTERNAL_API_URL=http://backend:${BACKEND_PORT}

